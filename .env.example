# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Set at least one depending on your chosen backend.

# OpenAI (GPT-4o-mini by default — fast and cheap)
OPENAI_API_KEY=sk-...

# Google Gemini (gemini-1.5-flash by default — free tier available)
GEMINI_API_KEY=...

# ── Notes ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# If you set embed_backend to "local" in the sidebar,
# no OPENAI_API_KEY is needed for embeddings.
# sentence-transformers will run fully locally.
