# ── LLM API Keys ─────────────────────────────────────────────────────────────
# Set at least one depending on your chosen backend.

# OpenAI (GPT-4o-mini by default — also used for Whisper audio transcription)
OPENAI_API_KEY=sk-...

# Google Gemini (gemini-2.5-flash by default — free tier may be available)
GEMINI_API_KEY=...

# ── Local LLM (no key) ───────────────────────────────────────────────────────
# Select LLM backend = "ollama" in the sidebar and run:
#   ollama run llama3
# Uses OpenAI-compatible API at http://localhost:11434/v1

# ── Notes ─────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Embedding backend "local" in the sidebar does not require OPENAI_API_KEY.
# sentence-transformers runs fully on-device for semantic search.
